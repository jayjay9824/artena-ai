# AXVELA AI — environment variables
# Copy this file to .env.local and fill in values.
# .env.local is git-ignored.

# Claude API — SERVER-ONLY. Never prefix with NEXT_PUBLIC_.
# Get a key at https://console.anthropic.com/
CLAUDE_API_KEY=

# Model alias. Active options (newest → oldest within Sonnet):
#   claude-sonnet-4-6   ← newest Sonnet (recommended upgrade target)
#   claude-sonnet-4-5   ← currently used per project spec
#   claude-opus-4-7     ← most capable, higher cost
#   claude-haiku-4-5    ← fastest, cheapest
CLAUDE_MODEL=claude-sonnet-4-5
