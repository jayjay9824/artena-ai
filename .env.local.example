# AXVELA AI — environment variables
# Copy this file to .env.local and fill in values.
# .env.local is git-ignored.

# ─────────────────────────────────────────────
# Claude API (Anthropic) — interpretation engine
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_.
# Get a key at https://console.anthropic.com/
# ─────────────────────────────────────────────
CLAUDE_API_KEY=

# Model alias. Active options (newest → oldest within Sonnet):
#   claude-sonnet-4-6   ← newest Sonnet (recommended upgrade target)
#   claude-sonnet-4-5   ← currently used per project spec
#   claude-opus-4-7     ← most capable, higher cost
#   claude-haiku-4-5    ← fastest, cheapest
CLAUDE_MODEL=claude-sonnet-4-5

# ─────────────────────────────────────────────
# Gemini API (Google) — verification layer
# SERVER-ONLY. Optional. If not set, Claude-only flow is used.
# Get a key at https://aistudio.google.com/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=

# Model. Vision-capable Flash variants recommended for verification.
#   gemini-2.0-flash    ← stable, fast, vision (default)
#   gemini-2.5-flash    ← newer, more capable
#   gemini-1.5-flash    ← legacy stable
GEMINI_MODEL=gemini-2.0-flash
